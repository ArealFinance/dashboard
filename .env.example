# Dashboard deployment target
DEPLOY_HOST=your-server.example.com
DEPLOY_PATH=/var/www/panel.example.com/

# -----------------------------------------------------------------------------
# Layer 8 — optional public env vars
# -----------------------------------------------------------------------------
# Heartbeat HTTP endpoints exposed by the three permissionless cranks.
# Each crank serves `GET /heartbeat → { lastRunTs, status, version }`.
# Leave blank to render the crank as "Unreachable" in the dashboard.
PUBLIC_CRANK_REVENUE_URL=
PUBLIC_CRANK_CONVERT_URL=
PUBLIC_CRANK_CLAIM_URL=

# Merkle-publisher proof-store base URL used by the yield-flows page when
# fetching published proofs (see `bots/merkle-publisher/src/proof-store.ts`).
# Leave blank to disable the proof inspector.
PUBLIC_PROOF_STORE_URL=

# Localnet RPC URL used when the network selector is set to "Test Validator".
# Leave blank to default to `http://127.0.0.1:8899` (the standard Solana
# test-validator endpoint). Operators with a hosted staging localnet override
# this to their own RPC. Used both for live RPC connections and for explorer
# `customUrl` links (Solana Explorer "custom" cluster).
PUBLIC_LOCALNET_RPC_URL=

# -----------------------------------------------------------------------------
# Layer 9 — optional public env vars
# -----------------------------------------------------------------------------
# Heartbeat HTTP endpoint exposed by the Nexus Manager bot. Same shape as
# the Layer 8 cranks (`GET /heartbeat → { lastRunTs, status, version }`).
# Leave blank to render the manager bot as "Unreachable".
PUBLIC_NEXUS_MANAGER_BOT_URL=

# USDC mint address (base58) for the active deployment.
# - Devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU (default if blank)
# - Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# MAINNET-REPLACE: must be set at mainnet release.
PUBLIC_USDC_MINT=
